# BSCS Gateway Docker Configuration
# Copy to .env and fill in values before deploying.

# User/group for running as non-root in container
UID=${UID:-1000}
GID=${GID:-1000}

# Path to BSCS config directory (contains config.json with provider API keys)
# The container mounts this read-only to /home/bscs/.config/bscs
BSCS_CONFIG_PATH=${HOME}/.config/bscs

# Config directory (used by cost tracking, fleet config)
# Override default ~/.config/bscs
BSCS_CONFIG_DIR=

# Gateway listen port (inside container and published to host)
BSCS_PORT=18999

# Host bind address — set to 0.0.0.0 to expose beyond localhost
BSCS_BIND_HOST=127.0.0.1

# Log level for the gateway process (debug, info, warn, error)
LOG_LEVEL=info
